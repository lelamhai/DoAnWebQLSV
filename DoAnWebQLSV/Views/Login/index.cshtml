@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Đăng nhập</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.10.0/css/bootstrap-datepicker3.min.css">

    <style>
        body {
            font-family: 'Roboto', sans-serif;
            background: #f7fbfa;
        }

        .login-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 1000px;
            min-height: 520px;
            background: #fff;
            border-radius: 22px;
            overflow: hidden;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.15);
            display: flex;
        }

        .login-left {
            width: 50%;
            background: linear-gradient(135deg, #08a56d, #007a68);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 50px;
        }

        .icon-box {
            width: 180px;
            height: 180px;
            border-radius: 22px;
            background: rgba(255, 255, 255, 0.14);
            border: 1px solid rgba(255, 255, 255, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 35px;
            box-shadow: 0 12px 25px rgba(0, 0, 0, 0.2);
        }

            .icon-box i {
                font-size: 78px;
                color: #d8fff2;
            }

        .login-left h2 {
            font-size: 30px;
            font-weight: 700;
            margin-bottom: 18px;
        }

        .login-left p {
            font-size: 18px;
            line-height: 1.6;
            opacity: 0.9;
        }

        .login-right {
            width: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 55px;
        }

        .form-box {
            width: 100%;
            max-width: 380px;
        }

            .form-box h3 {
                font-size: 30px;
                font-weight: 700;
                color: #1f2937;
                margin-bottom: 8px;
            }

            .form-box .sub-title {
                color: #6b7280;
                margin-bottom: 35px;
            }

        .input-group-text {
            background: white;
            border-right: none;
            color: #9ca3af;
        }

        .form-control {
            border-left: none;
            height: 43px;
            font-size: 15px;
        }

            .form-control:focus {
                box-shadow: none;
                border-color: #dee2e6;
            }

        .input-group {
            border-radius: 12px;
            overflow: hidden;
        }

        .remember-row {
            font-size: 14px;
        }

        .forgot-link {
            color: #2563eb;
            text-decoration: none;
            font-weight: 500;
        }

        .btn-login {
            background: #079b70;
            color: white;
            height: 45px;
            border-radius: 12px;
            font-weight: 600;
            border: none;
        }

            .btn-login:hover {
                background: #078765;
                color: white;
            }

        .recaptcha-text {
            margin-top: 28px;
            font-size: 13px;
            color: #6b7280;
            text-align: center;
            line-height: 1.5;
        }

            .recaptcha-text a {
                color: #374151;
            }

   

        .login-left,
        .login-right {
            width: 100%;
        }

        .login-left {
            padding: 40px 25px;
        }

        }
    </style>
</head>

<body>

    <div class="login-wrapper">
        <div class="login-card">

            <div class="login-left">
                <div>
                    <div class="icon-box">
                        <i class="fa-solid fa-graduation-cap"></i>
                    </div>

                    <h2>Student Management</h2>

                    <p>
                        Hệ thống quản lý sinh viên và giảng<br>
                        viên chuyên nghiệp, hiệu quả.
                    </p>
                </div>
            </div>

            <div class="login-right">
                <div class="form-box">
                    <h3>Xin chào 👋</h3>
                    <p class="sub-title">Vui lòng đăng nhập để tiếp tục</p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <form asp-controller="Login" asp-action="Index" method="post">
                        @Html.AntiForgeryToken()

                        <div class="input-group mb-3">
                            <span class="input-group-text">
                                <i class="fa-regular fa-user"></i>
                            </span>
                            <input type="text" name="username" class="form-control" placeholder="Username đăng nhập" required>
                        </div>

                        <div class="input-group mb-3">
                            <span class="input-group-text">
                                <i class="fa-solid fa-lock"></i>
                            </span>
                            <input type="password" id="password" name="password" class="form-control" placeholder="Mật khẩu" required>
                            <span class="input-group-text" style="border-left: none; cursor: pointer;" onclick="togglePassword()">
                                <i id="eyeIcon" class="fa-regular fa-eye-slash"></i>
                            </span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4 remember-row">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="remember" checked>
                                <label class="form-check-label" for="remember">
                                    Ghi nhớ đăng nhập
                                </label>
                            </div>

                            <a href="#" class="forgot-link">Quên mật khẩu?</a>
                        </div>

                        <button type="submit" class="btn btn-login w-100">
                            Đăng nhập
                            <i class="fa-solid fa-arrow-right-to-bracket ms-2"></i>
                        </button>

                        <p class="recaptcha-text">
                            Protected by reCAPTCHA and subject to the Google<br>
                            <a href="#">Privacy Policy</a> and
                            <a href="#">Terms of Service</a>.
                        </p>

                    </form>
                </div>
            </div>

        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.10.0/js/bootstrap-datepicker.min.js"></script>

    <script>
        function togglePassword() {
            const password = document.getElementById("password");
            const eyeIcon = document.getElementById("eyeIcon");

            if (password.type === "password") {
                password.type = "text";
                eyeIcon.className = "fa-regular fa-eye";
            } else {
                password.type = "password";
                eyeIcon.className = "fa-regular fa-eye-slash";
            }
        }
    </script>

</body>
</html>