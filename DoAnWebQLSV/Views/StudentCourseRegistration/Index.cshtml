@{
    var ltcs = ViewBag.LTCData;
}
@section Styles {
    <link rel="stylesheet" href="~/assets/css/register-course.css" />
}
<section class="content-wrap">
    <div class="page-title-row">
        <div class="page-title-group">
            <div class="title-icon"><i class="fa-regular fa-square-plus"></i></div>
            <div>
                <h1>Đăng ký môn học</h1>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="table-toolbar">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Tìm kiếm theo tên môn" />
            </div>
        </div>

       

        <div class="table-responsive">
            <table class="course-table">
                <thead>
                    <tr>
                        <th>Mã lớp HP</th>
                        <th>Môn học</th>
                        <th>Giảng viên</th>
                        <th>Học kỳ</th>
                        <th>Sĩ số</th>
                        <th>Lịch học</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>

                    @if (ltcs != null)
                    {
                        @foreach (var item in ltcs.Items)
                        {
                            bool lopDaDay = item.SiSoHienTai >= item.SiSoToiDa;

                            <tr>
                                <td class="code">
                                    @item.MaLtc
                                </td>

                                <td>
                                    <strong>@item.TenMh</strong>
                                    <small>@item.MaMh · @item.SoTinChi TC</small>
                                </td>

                                <td>
                                    @(string.IsNullOrEmpty(item.TenGiangVien)
                                                                ? "Chưa phân công"
                                                                : item.TenGiangVien)
                        </td>

                                <td>
                                    <span class="term">
                                        Học Kỳ @item.HocKy
                                    </span>
                                </td>

                                <td>
                                    @item.SiSo
                                </td>

                                <td>
                                    <strong>@item.DayThuTrongTuan</strong>
                                    <small>@item.ThoiGianHoc</small>
                                </td>

                                <td>
                            @if (item.HuyLop)
                                    {
                                        <button type="button"
                                                class="register-btn"
                                                disabled>
                                            Đã hủy
                                        </button>
                                    }
                                    else if (lopDaDay)
                                    {
                                        <button type="button"
                                                class="register-btn"
                                                disabled>
                                            Đã đầy
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="register-btn"
                                                data-maltc="@item.MaLtc">
                                            Đăng ký
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination-wrapper">
            <nav class="pagination">
                <button class="pagination-btn pagination-prev" title="Trang trước">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>
                <button class="pagination-page active">1</button>
                <button class="pagination-btn pagination-next" title="Trang sau">
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </nav>
        </div>
    </div>
</section>
@section Scripts {
    <script src="~/assets/js/register-course.js"></script>
}