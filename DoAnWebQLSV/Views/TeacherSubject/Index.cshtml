@{
    var subjects = ViewBag.Subjects;
}
<section class="content-wrap">
    <div class="page-title-row">
        <div class="page-title-group">
            <div class="title-icon"><i class="fa-regular fa-square-plus"></i></div>
            <div>
                <h1>Môn học</h1>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="table-toolbar">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Tìm kiếm theo tên môn" />
            </div>
        </div>

        <div class="table-responsive">
            <table class="course-table">
                <thead>
                    <tr>
                        <th>Mã lớp HP</th>
                        <th>Môn học</th>
                        <th>Giảng viên</th>
                        <th>Học kỳ</th>
                        <th>Sĩ số</th>
                        <th>Lịch học</th>
                    </tr>
                </thead>
                <tbody>
                    @if (subjects != null)
                    {
                        @foreach (var item in subjects.Items)
                        {
                            <tr>
                                <td class="code">
                                    @item.MaLtc
                                </td>

                                <td>
                                    <strong>@item.TenMh</strong>
                                    <small>@item.MaMh · @item.SoTinChi TC</small>
                                </td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(item.TenGiangVien)
                                                                ? "Chưa phân công"
                                                                : item.TenGiangVien)
                        </td>

                                <td>
                                    <span class="term">
                                        Học Kỳ @item.HocKy
                                    </span>
                                </td>

                                <td>
                                    @item.SiSoHienTai
                                </td>

                                <td class="no-right">
                                    <strong>@item.LichHoc</strong>
                                    <small>@item.ThoiGianHoc</small>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination-wrapper">
            <nav class="pagination">
                <button class="pagination-btn pagination-prev" title="Trang trước">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>
                <button class="pagination-page active">1</button>
                <button class="pagination-btn pagination-next" title="Trang sau">
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </nav>
        </div>
    </div>
</section>