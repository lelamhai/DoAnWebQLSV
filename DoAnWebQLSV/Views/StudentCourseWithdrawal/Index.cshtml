@section Styles {
    <link rel="stylesheet" href="~/assets/css/my-course.css" />
}
<section class="content-wrap">

    <div class="course-summary">
        <div class="summary-card">
            <div class="summary-icon"><i class="fa-solid fa-book-open"></i></div>
            <div class="summary-content">
                <span class="summary-label">Số môn</span>
                <strong>7 môn</strong>
            </div>
        </div>
        <div class="summary-card">
            <div class="summary-icon"><i class="fa-solid fa-award"></i></div>
            <div class="summary-content">
                <span class="summary-label">Số tín chỉ</span>
                <strong>20 tín chỉ</strong>
            </div>
        </div>
    </div>

    <div class="page-title-row">
        <div class="page-title-group">
            <div class="title-icon"><i class="fa-regular fa-square-plus"></i></div>
            <div>
                <h1>Môn học đã đăng ký</h1>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="table-toolbar">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Tìm kiếm theo tên môn" />
            </div>
            <button class="filter-btn" id="filter-toggle" aria-expanded="false"><i class="fa-solid fa-filter"></i> Lọc</button>
        </div>

        <div class="filter-panel" id="filter-panel" aria-hidden="true">
            <div class="filter-fields">
                <div class="filter-group">
                    <label for="classroom">Lớp học</label>
                    <select id="classroom" class="filter-select">
                        <option value="">Tất cả lớp học</option>
                        <option value="cntt-01">CNTT-01</option>
                        <option value="int1001-1">INT1001_1</option>
                        <option value="int1001-2">INT1001_2</option>
                        <option value="int1002-1">INT1002_1</option>
                        <option value="int1002-2">INT1002_2</option>
                        <option value="int1003-1">INT1003_1</option>
                        <option value="int1003-2">INT1003_2</option>
                        <option value="int1004-1">INT1004_1</option>
                        <option value="int1004-2">INT1004_2</option>
                        <option value="int1004-3">INT1004_3</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="course-table">
                <thead>
                    <tr>
                        <th>Mã lớp HP</th>
                        <th>Môn học</th>
                        <th>Giảng viên</th>
                        <th>Lịch học</th>
                        <th>Ngày đăng ký</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="code">CNTT-01</td>
                        <td><strong>Cấu trúc dữ liệu và giải thuật</strong><small>INT1002 · 4 TC</small></td>
                        <td>Bùi Xuân Phúc</td>
                        <td><strong>Thứ: 2, 4, 5</strong><small>01/03/2026 - 30/05/2026</small></td>
                        <td>15/02/2026</td>
                        <td><button class="register-btn cancel-btn"><i class="fa-solid fa-trash"></i> Hủy</button></td>
                    </tr>
                    <tr>
                        <td class="code">INT1001_1</td>
                        <td><strong>Nhập môn lập trình</strong><small>INT1001 · 3 TC</small></td>
                        <td>Huỳnh Thanh Nam</td>
                        <td><strong>Thứ: 3, 5</strong><small>05/03/2026 - 02/06/2026</small></td>
                        <td>15/02/2026</td>
                        <td><button class="register-btn cancel-btn"><i class="fa-solid fa-trash"></i> Hủy</button></td>
                    </tr>
                    <tr>
                        <td class="code">INT1001_2</td>
                        <td><strong>Nhập môn lập trình</strong><small>INT1001 · 3 TC</small></td>
                        <td>Ngô Hoàng Đạt</td>
                        <td><strong>Thứ: 2, 4</strong><small>03/03/2026 - 28/05/2026</small></td>
                        <td>15/02/2026</td>
                        <td><button class="register-btn cancel-btn"><i class="fa-solid fa-trash"></i> Hủy</button></td>
                    </tr>
                    <tr>
                        <td class="code">INT1002_1</td>
                        <td><strong>Cấu trúc dữ liệu và giải thuật</strong><small>INT1002 · 4 TC</small></td>
                        <td>Ngô Hoàng Đạt</td>
                        <td><strong>Thứ: 2, 4, 5</strong><small>15/05/2025 - 15/08/2025</small></td>
                        <td>15/02/2026</td>
                        <td><button class="register-btn cancel-btn"><i class="fa-solid fa-trash"></i> Hủy</button></td>
                    </tr>
                    <tr>
                        <td class="code">INT1002_2</td>
                        <td><strong>Cấu trúc dữ liệu và giải thuật</strong><small>INT1002 · 4 TC</small></td>
                        <td>Bùi Xuân Quang</td>
                        <td><strong>Thứ: 3, 5</strong><small>18/09/2024 - 15/12/2024</small></td>
                        <td>15/02/2026</td>
                        <td><button class="register-btn cancel-btn"><i class="fa-solid fa-trash"></i> Hủy</button></td>
                    </tr>
                    <tr>
                        <td class="code">INT1003_1</td>
                        <td><strong>Lập trình hướng đối tượng</strong><small>INT1003 · 3 TC</small></td>
                        <td>Bùi Xuân Quang</td>
                        <td><strong>Thứ: 2, 4</strong><small>18/09/2024 - 15/12/2024</small></td>
                        <td>15/02/2026</td>
                        <td><button class="register-btn cancel-btn"><i class="fa-solid fa-trash"></i> Hủy</button></td>
                    </tr>
                    <tr>
                        <td class="code">INT1003_2</td>
                        <td><strong>Lập trình hướng đối tượng</strong><small>INT1003 · 3 TC</small></td>
                        <td>Lê Văn Khang</td>
                        <td><strong>Thứ: 3, 5</strong><small>20/05/2025 - 20/08/2025</small></td>
                        <td>15/02/2026</td>
                        <td><button class="register-btn cancel-btn"><i class="fa-solid fa-trash"></i> Hủy</button></td>
                    </tr>
                    <tr>
                        <td class="code">INT1004_1</td>
                        <td><strong>Cơ sở dữ liệu</strong><small>INT1004 · 4 TC</small></td>
                        <td>Lê Văn Khang</td>
                        <td><strong>Thứ: 2, 4, 5</strong><small>20/05/2025 - 20/08/2025</small></td>
                        <td>15/02/2026</td>
                        <td><button class="register-btn cancel-btn"><i class="fa-solid fa-trash"></i> Hủy</button></td>
                    </tr>
                    <tr>
                        <td class="code">INT1004_2</td>
                        <td><strong>Cơ sở dữ liệu</strong><small>INT1004 · 4 TC</small></td>
                        <td>Trần Phương Cường</td>
                        <td><strong>Thứ: 3, 5</strong><small>01/03/2026 - 30/05/2026</small></td>
                        <td>15/02/2026</td>
                        <td><button class="register-btn cancel-btn"><i class="fa-solid fa-trash"></i> Hủy</button></td>
                    </tr>
                    <tr>
                        <td class="code">INT1004_3</td>
                        <td><strong>Cơ sở dữ liệu</strong><small>INT1004 · 4 TC</small></td>
                        <td>Phan Xuân Nam</td>
                        <td><strong>Thứ: 2, 4</strong><small>01/03/2026 - 30/05/2026</small></td>
                        <td>15/02/2026</td>
                        <td><button class="register-btn cancel-btn"><i class="fa-solid fa-trash"></i> Hủy</button></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="pagination-wrapper">
            <nav class="pagination">
                <button class="pagination-btn pagination-prev" title="Trang trước">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>
                <button class="pagination-page active">1</button>
                <button class="pagination-btn pagination-next" title="Trang sau">
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </nav>
        </div>
    </div>
</section>
@section Scripts {
    <script src="~/assets/js/my-course.js"></script>
}