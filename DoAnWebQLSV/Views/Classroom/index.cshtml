@{
    var classrooms = ViewBag.Classrooms;
    var statusClassroom = ViewBag.StatusClassroom;
	var faculty = ViewBag.Faculty;
}

@section Styles {
    <link rel="stylesheet" href="~/assets/css/classroom.css" />
}
<section class="content-wrap">
    <div class="page-title-row">
        <div class="page-title-group">
            <div class="title-icon"><i class="fa-solid fa-school"></i></div>
            <div>
                <h1>Quản lý lớp học</h1>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="table-toolbar">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="student-search" placeholder="Tìm kiếm theo tên lớp" />
            </div>
            <div class="toolbar-actions">
                <button class="add-course-btn" type="button" id="add-student-btn">
                    <i class="fa-solid fa-circle-plus"></i>
                    <span>Thêm lớp học</span>
                </button>
            </div>
        </div>

        <div class="filter-panel" id="filter-panel" aria-hidden="true">
            <div class="filter-fields student-filter-grid">
                <div class="filter-group">
                    <label for="filter-class">Khóa học</label>
                    <select id="filter-class" class="filter-select">
                        <option value="">Tất cả khóa</option>
                        <option value="K23">K23</option>
                        <option value="K22">K22</option>
                        <option value="K21">K21</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label for="filter-gender">Khoa</label>
                    <select id="filter-gender" class="filter-select">
                        <option value="">Tất cả khoa</option>
                        <option value="CNTT">Công nghệ thông tin</option>
                        <option value="KTPM">Kỹ thuật phần mềm</option>
                        <option value="HTTT">Hệ thống thông tin</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label for="filter-status">Trạng thái</label>
                    <select id="filter-status" class="filter-select">
                        <option value="">Tất cả trạng thái</option>
                        <option value="Hoạt động">Hoạt động</option>
                        <option value="Tạm dừng">Tạm dừng</option>
                        <option value="Kết thúc">Kết thúc</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="course-table student-table" id="student-table">
                <thead>
                    <tr>
                        <th>Khoa</th>
                        <th>Mã lớp</th>
                        <th>Tên lớp</th>
                        <th>Khóa học</th>
                        <th>Ngày mở lớp</th>
                        <th>Trạng thái</th>
                        <th class="actions-header"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (classrooms != null)
                    {
                        @foreach (var item in classrooms.Items)
                        {
                            <tr data-malop="@item.MaLop" data-tenlop="@item.TenLop" data-khoahoc="@item.KhoaHoc" data-makhoa="@item.TenKhoa" data-manv="@item.TenNhanVien" data-ngaymolop="@item.NgayMoLop" data-trangthai="@item.TrangThai">
                                <td><strong>@item.TenKhoa</strong></td>
                                <td class="code">@item.MaLop</td>
                                <td>@item.TenLop</td>
                                <td>@item.KhoaHoc</td>
                                <td>@item.NgayMoLop</td>
                                <td><span class="student-status status-active">@item.TrangThai</span></td>
                                <td class="actions-cell"><div class="course-actions"><button type="button" class="action-btn edit-btn" data-malop="@item.MaLop" title="Sửa" aria-label="Sửa lớp học"><i class="fa-solid fa-pen"></i></button><button type="button" class="action-btn delete-btn" data-malop="@item.MaLop" title="Xóa" aria-label="Xóa lớp học"><i class="fa-solid fa-trash"></i></button></div></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="8">Không có dữ liệu</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination-wrapper">
            <nav class="pagination">
                @if (classrooms != null)
                {
                    <a href="?page=1" class="pagination-btn pagination-prev" title="Trang trước"><i class="fa-solid fa-chevron-left"></i></a>
                    for (int i = 1; i <= classrooms.Pagination.TotalPages; i++)
                    {
                        if(i==1)
                        {
                            <a href="?page=@i" class="pagination-page active">@i</a>
                        }
                        else
                        {
                            <a href="?page=@i" class="pagination-page">@i</a>
                        }
                    }
                    <a href="?page=@classrooms.Pagination.TotalPages" class="pagination-btn pagination-next" title="Trang sau"><i class="fa-solid fa-chevron-right"></i></a>
                }
            </nav>
        </div>
    </div>
</section>
<!-- Slide-in Add Classroom Panel -->
<div class="slide-panel-overlay" id="add-panel-overlay" aria-hidden="true"></div>
<aside class="slide-panel" id="add-student-panel" aria-hidden="true" role="dialog" aria-label="Thêm lớp học">
    <div class="slide-panel-header">
        <h3>Thêm lớp học</h3>
        <button type="button" class="close-panel" id="close-add-panel" aria-label="Đóng">&times;</button>
    </div>
    <form id="add-student-form" class="slide-panel-body">
        <div class="form-row two-cols">
            <div>
                <label for="add-masv">Mã lớp</label>
                <input type="text" id="add-masv" />
            </div>
            <div>
                <label for="add-ho">Tên lớp</label>
                <input type="text" id="add-ho" />
            </div>
        </div>
        <div class="form-row two-cols">
            <div>
                <label for="edit-ten">Khóa học</label>
                <input type="text" id="add-hoc" />
            </div>
            <div>
                <label for="edit-phai">Khoa</label>
                <select id="edit-phai" class="filter-select">
                    @if (faculty != null)
                    {
                        @foreach (var item in faculty)
                        {
                            <option value="@item.MaKhoa">@item.TenKhoa</option>
                        }
                    }
                </select>
            </div>
        </div>
        <div class="form-row two-cols">
            <div>
                <label for="edit-ngaysinh">Ngày mở lớp</label>
                <input type="text" id="edit-ngaysinh" class="date-picker" />
            </div>
            <div>
                <label for="add-danghoc">Trạng thái</label>
                <select id="add-danghoc" class="filter-select">
                    @if (statusClassroom != null)
                    {
                        @foreach (var item in statusClassroom)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="form-actions">
            <button type="button" id="cancel-add-student" class="filter-btn">Hủy</button>
            <button type="button" id="submit-add-student" class="add-course-btn">Thêm mới</button>
        </div>
    </form>
</aside>

<!-- Slide-in Edit Classroom Panel -->
<div class="slide-panel-overlay" id="edit-panel-overlay" aria-hidden="true"></div>
<aside class="slide-panel" id="edit-student-panel" aria-hidden="true" role="dialog" aria-label="Chỉnh sửa lớp học">
    <div class="slide-panel-header">
        <h3>Chỉnh sửa lớp học</h3>
        <button type="button" class="close-panel" id="close-edit-panel" aria-label="Đóng">&times;</button>
    </div>
    <form id="edit-student-form" class="slide-panel-body" asp-controller="Classroom" asp-action="Update" method="post">
        @Html.AntiForgeryToken()
        <div class="form-row two-cols">
            <div>
                <label for="edit-masv">Mã lớp</label>
                <input type="text" id="edit-masv" name="MaLop" readonly />
            </div>
            <div>
                <label for="edit-tenlop">Tên lớp</label>
                <input type="text" id="edit-tenlop" name="TenLop" />
            </div>
        </div>
        <div class="form-row two-cols">
            <div>
                <label for="edit-khoahoc">Khóa học</label>
                <input type="text" id="edit-khoahoc" name="KhoaHoc" />
            </div>
            <div>
                <label for="edit-khoa">Khoa</label>
                <select id="edit-khoa" name="MaKhoa" class="filter-select">
                    @if (faculty != null)
                    {
                        @foreach (var item in faculty)
                        {
                            <option value="@item.MaKhoa">@item.TenKhoa</option>
                        }
                    }
                </select>
            </div>
        </div>
        <div class="form-row two-cols">
            
            <div>
                <label for="edit-ngaymolop">Ngày mở lớp</label>
                <input type="text" id="edit-ngaymolop" name="NgayMoLop" class="date-picker" placeholder="dd/mm/yyyy" />
            </div>
            <div>
                <div class="form-row">
                    <label for="edit-trangthai">Trạng thái</label>
                    <select id="edit-trangthai" name="TrangThai" class="filter-select">
                        @if (statusClassroom != null)
                        {
                            @foreach (var item in statusClassroom)
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
        

        <div class="form-actions">
            <button type="button" id="cancel-edit-student" class="filter-btn">Hủy</button>
            <button type="submit" id="submit-edit-student" class="add-course-btn">Lưu thay đổi</button>
        </div>
    </form>
</aside>
@section Scripts {
    <script src="~/assets/js/classroom.js"></script>
    <script>
    document.addEventListener("DOMContentLoaded", function () {
        const deleteButtons = document.querySelectorAll(".delete-btn");
                const editButtons = document.querySelectorAll(".edit-btn");


        deleteButtons.forEach(button => {
            button.addEventListener("click", async function () {
                const maLop = this.getAttribute("data-malop");

                if (!maLop) {
                    alert("Không tìm thấy mã lớp cần xóa.");
                    return;
                }

                const confirmDelete = confirm(`Bạn có chắc muốn xóa lớp ${maLop} không?`);

                if (!confirmDelete) {
                    return;
                }

                try {
                    const response = await fetch(`/Classroom/Delete?maLop=${encodeURIComponent(maLop)}`, {
                        method: "DELETE"
                    });

                    const text = await response.text();

                    if (response.ok) {
                        alert("Xóa lớp thành công.");
                        window.location.reload();
                    } else {
                        alert("Xóa thất bại.");
                    }
                } catch (error) {
                    alert("Có lỗi xảy ra khi xóa lớp: " + error.message);
                }
            });
        });


            editButtons.forEach(button => {
                button.addEventListener("click", async function () {
                    const maLop = this.getAttribute("data-malop");

                    if (!maLop) {
                        alert("Không tìm thấy mã lớp cần xóa.");
                        return;
                    }

                   
                    try {
                        const response = await fetch(`/Classroom/Detail?maLop=${encodeURIComponent(maLop)}`, {
                            method: "GET"
                        });

                            const text  = await response.text();
                                const data = JSON.parse(text);
                        if (response.ok) {
                            const lop = data[0];

                                console.log(lop);
                                        console.log(lop.trangthai);

                            document.getElementById("edit-masv").value = lop.malop;
                            document.getElementById("edit-tenlop").value = lop.tenlop;
                            document.getElementById("edit-khoahoc").value = lop.khoahoc;
                            document.getElementById("edit-ngaymolop").value = lop.ngaymolop;

                                 document.getElementById("edit-trangthai").value = String(lop.trangthai);
                                         document.getElementById("edit-khoa").value = String(lop.makhoa);
                        } else {
                            alert("edit lỗi.");
                        }
                    } catch (error) {
                        alert("Có lỗi xảy ra khi xóa lớp: " + error.message);
                    }
                });
            });


    });

          
</script>
}


