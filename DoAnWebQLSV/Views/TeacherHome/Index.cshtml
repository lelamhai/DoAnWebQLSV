@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@section Styles {
    <link rel="stylesheet" href="~/assets/css/dashboard.css" />
}
<section class="content-wrap dashboard-wrap">
    <div class="dashboard-grid">
        <aside class="dashboard-panel dashboard-right-column">
            <div class="dashboard-panel-header">
                <div>
                    <h2>Thông tin giảng viên</h2>
                </div>
            </div>

            <div class="student-card">
                <div class="student-avatar">LH</div>
                <div class="student-info">
                    <strong>Lê Lam Hải</strong>
                    <span>K23DTCN426</span>
                    <small>Công nghệ thông tin</small>
                </div>
            </div>

            <div class="student-detail-list">
                <div class="student-detail-item">
                    <span class="student-detail-label">Trạng thái</span>
                    <strong>Đang hoạt</strong>
                </div>
                <div class="student-detail-item">
                    <span class="student-detail-label">Lớp sinh hoạt</span>
                    <strong>DTCN-K23A</strong>
                </div>
                <div class="student-detail-item">
                    <span class="student-detail-label">Cố vấn học tập</span>
                    <strong>ThS. Bùi Xuân Phúc</strong>
                </div>
            </div>
        </aside>

        <section class="dashboard-panel dashboard-actions-panel">
            <div class="dashboard-panel-header">
                <div>
                    <h2>Thời khóa biểu</h2>
                </div>
            </div>

            <div class="dashboard-actions">
                <a class="dashboard-action-card" href="register-course.html">
                    <div class="dashboard-action-icon action-register"><i class="fa-regular fa-clipboard"></i></div>
                    <div class="dashboard-action-content">
                        <h3>Đăng ký môn</h3>
                        <p>Xem danh sách lớp mở và đăng ký môn học.</p>
                    </div>
                    <i class="fa-solid fa-arrow-right dashboard-action-arrow"></i>
                </a>

                <a class="dashboard-action-card" href="my-course.html">
                    <div class="dashboard-action-icon action-course"><i class="fa-regular fa-square-check"></i></div>
                    <div class="dashboard-action-content">
                        <h3>Môn đã đăng ký</h3>
                        <p>Kiểm tra các lớp học phần đang theo học.</p>
                    </div>
                    <i class="fa-solid fa-arrow-right dashboard-action-arrow"></i>
                </a>

                <a class="dashboard-action-card" href="my-score.html">
                    <div class="dashboard-action-icon action-score"><i class="fa-solid fa-trophy"></i></div>
                    <div class="dashboard-action-content">
                        <h3>Bảng điểm</h3>
                        <p>Theo dõi kết quả học tập và xếp loại.</p>
                    </div>
                    <i class="fa-solid fa-arrow-right dashboard-action-arrow"></i>
                </a>

                <a class="dashboard-action-card" href="paid-course.html">
                    <div class="dashboard-action-icon action-paid"><i class="fa-solid fa-money-bill-wave"></i></div>
                    <div class="dashboard-action-content">
                        <h3>Học phí</h3>
                        <p>Xem tổng tiền, đã thu và số dư học phí.</p>
                    </div>
                    <i class="fa-solid fa-arrow-right dashboard-action-arrow"></i>
                </a>
            </div>
        </section>
    </div>
</section>
@section Scripts {
    <script src="~/assets/js/dashboard.js"></script>
}