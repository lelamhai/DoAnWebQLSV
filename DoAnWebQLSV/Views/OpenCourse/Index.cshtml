@{
    var ltcs = ViewBag.LTCs;
    var subjects = ViewBag.Subjects;
    var teachers = ViewBag.Teachers;
    var a = 1;
}

@section Styles {
    <link rel="stylesheet" href="~/assets/css/open-course.css" />
}
<section class="content-wrap">
    <div class="page-title-row">
        <div class="page-title-group">
            <div class="title-icon"><i class="fa-regular fa-square-plus"></i></div>
            <div>
                <h1>Quản lý học phần</h1>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="table-toolbar">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Tìm kiếm theo tên môn" />
            </div>
            <div class="toolbar-actions">
                <button class="add-course-btn" type="button" id="add-course-btn">
                    <i class="fa-solid fa-circle-plus"></i>
                    <span>Mở môn mới</span>
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="course-table">
                <thead>
                    <tr>
                        <th>Mã lớp HP</th>
                        <th>Môn học</th>
                        <th>Giảng viên</th>
                        <th>Học kỳ</th>
                        <th>Sĩ số</th>
                        <th>Lịch học</th>
                        <th class="actions-header"></th>
                    </tr>
                </thead>
                <tbody>

                    @if (ltcs != null)
                    {
                        @foreach (var item in ltcs.Items)
                        {
                            <tr>
                                <td class="code">
                                    @item.MaLopHp
                                </td>

                                <td>
                                    <strong>@item.TenMh</strong>
                                    <small>
                                        @item.MaMh · @item.SoTinChi TC
                                    </small>
                                </td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(item.TenGiangVien)
                                                                ? "Chưa phân công"
                                                                : item.TenGiangVien)
                        </td>

                                <td>
                                    <span class="term">
                                        Học kỳ @item.HocKy
                                    </span>
                                </td>

                                <td>
                                    @item.SiSo
                                </td>

                                <td>
                                    <strong>@item.LichHoc</strong>
                                    <small>@item.ThoiGianHoc</small>
                                </td>

                                <td class="actions-cell">
                                    <div class="course-actions">
                                        <button type="button"
                                                class="action-btn edit-btn"
                                                data-maltc="@item.MaLtc"
                                                data-malophp="@item.MaLopHp"
                                                data-mamh="@item.MaMh"
                                                data-magv="@item.MaGv"
                                                data-hocky="@item.HocKy"
                                                data-nienkhoa="@item.NienKhoa"
                                                data-sisotoida="@item.SiSoToiDa"
                                                data-daythu="@item.DayThuTrongTuan"
                                                data-ngaybatdau="@(item.ThoiGianBatDau?.ToString("yyyy-MM-dd"))"
                                                data-ngayketthuc="@(item.ThoiGianKetThuc?.ToString("yyyy-MM-dd"))"
                                                title="Sửa"
                                                aria-label="Sửa lớp học phần">
                                            <i class="fa-solid fa-pen"></i>
                                        </button>

                                        <button type="button"
                                                class="action-btn delete-btn"
                                                data-maltc="@item.MaLtc"
                                                data-malophp="@item.MaLopHp"
                                                data-tenmh="@item.TenMh"
                                                title="Xóa"
                                                aria-label="Xóa lớp học phần">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }

                    }
                </tbody>
            </table>
        </div>

        <div class="pagination-wrapper">
            <nav class="pagination">
                @if (ltcs != null)
                {
                    <a href="?page=1" class="pagination-btn pagination-prev" title="Trang trước"><i class="fa-solid fa-chevron-left"></i></a>
                    for (int i = 1; i <= ltcs.Pagination.TotalPages; i++)
                    {
                        if (i == ltcs.Pagination.Page)
                        {
                            <a href="?page=@i" class="pagination-page active">@i</a>
                        }
                        else
                        {
                            <a href="?page=@i" class="pagination-page">@i</a>
                        }
                    }
                    <a href="?page=@ltcs.Pagination.TotalPages" class="pagination-btn pagination-next" title="Trang sau"><i class="fa-solid fa-chevron-right"></i></a>
                }
            </nav>
        </div>
    </div>
</section>
<!-- Slide-in Add Course Panel -->
<div class="slide-panel-overlay" id="add-panel-overlay" aria-hidden="true"></div>
<aside class="slide-panel" id="add-course-panel" aria-hidden="true" role="dialog" aria-label="Thêm mới môn học">
    <div class="slide-panel-header">
        <h3>Thêm mới môn học</h3>
        <button type="button" class="close-panel" id="close-add-panel" aria-label="Đóng">&times;</button>
    </div>
    <form id="add-course-form"
          class="slide-panel-body"
          action="/OpenCourse/CreateLTC"
          method="post">

        @Html.AntiForgeryToken()

        <div class="form-row">
            <label for="add-academic-year">Niên khóa</label>
            <input type="text"
                   id="add-academic-year"
                   name="NienKhoa"
                   class="year-picker"
                   maxlength="9"
                   placeholder="Ví dụ: 2025-2026"
                   required />
        </div>

        <div class="form-row">
            <label for="add-term">Học kỳ</label>
            <select id="add-term"
                    name="HocKy"
                    class="filter-select"
                    required>
                <option value="">-- Chọn học kỳ --</option>
                <option value="1">Học kỳ 1</option>
                <option value="2">Học kỳ 2</option>
                <option value="3">Học kỳ 3</option>
                <option value="4">Học kỳ 4</option>
                <option value="5">Học kỳ 5</option>
                <option value="6">Học kỳ 6</option>
                <option value="7">Học kỳ 7</option>
                <option value="8">Học kỳ 8</option>
                <option value="9">Học kỳ 9</option>
            </select>
        </div>

        <div class="form-row">
            <label for="add-course-name">Tên môn học</label>
            <select id="add-course-name"
                    name="MaMH"
                    class="filter-select"
                    required>

                <option value="">-- Chọn môn học --</option>

                @if (subjects?.Items != null)
                {
                    foreach (var item in subjects.Items)
                    {
                        <option value="@item.MaMh">
                            @item.TenMh
                        </option>
                    }
                }
            </select>
        </div>

        <div class="form-row">
            <label for="add-lecturer">Giảng viên</label>
            <select id="add-lecturer"
                    name="MaGV"
                    class="filter-select"
                    required>

                <option value="">-- Chọn giảng viên --</option>

                @if (teachers?.Items != null)
                {
                    foreach (var item in teachers.Items)
                    {
                        <option value="@item.MaGV">
                            @item.Ho @item.Ten
                        </option>
                    }
                }
            </select>
        </div>

        <div class="form-row two-cols">
            <div>
                <label for="add-max-size">Sĩ số tối đa</label>
                <input type="number"
                       id="add-max-size"
                       name="SiSoToiDa"
                       min="1"
                       required />
            </div>

            <div>
                <label for="add-weekdays">
                    Dạy thứ (ví dụ: Thứ 2,4,5)
                </label>
                <input type="text"
                       id="add-weekdays"
                       name="DayThuTrongTuan"
                       maxlength="50"
                       required />
            </div>
        </div>

        <div class="form-row two-cols">
            <div>
                <label for="add-start-date">Thời gian bắt đầu</label>
                <input type="date"
                       id="add-start-date"
                       name="ThoiGianBatDau"
                       class="date-picker" />
            </div>

            <div>
                <label for="add-end-date">Thời gian kết thúc</label>
                <input type="date"
                       id="add-end-date"
                       name="ThoiGianKetThuc"
                       class="date-picker" />
            </div>
        </div>

        <div class="form-row">
            <label for="add-status">Trạng thái</label>
            <select id="add-status"
                    name="HuyLop"
                    class="filter-select">

                <option value="false">Mở</option>
                <option value="true">Đóng/Hủy</option>
            </select>
        </div>

        <div class="form-actions">
            <button type="submit"
                    id="submit-add-course"
                    class="add-course-btn">
                Thêm mới
            </button>

            <button type="button"
                    id="cancel-add-course"
                    class="filter-btn">
                Hủy
            </button>
        </div>
    </form>
</aside>

<!-- Slide-in Edit Course Panel -->
<div class="slide-panel-overlay" id="edit-panel-overlay" aria-hidden="true"></div>
<aside class="slide-panel" id="edit-course-panel" aria-hidden="true" role="dialog" aria-label="Chỉnh sửa môn học">
    <div class="slide-panel-header">
        <h3>Chỉnh sửa môn học</h3>
        <button type="button" class="close-panel" id="close-edit-panel" aria-label="Đóng">&times;</button>
    </div>
    <form id="edit-course-form" class="slide-panel-body" >
        @Html.AntiForgeryToken()
        <div class="form-row">
            <label for="edit-academic-year">Niên khóa</label>
            <input type="text" id="edit-academic-year" class="year-picker" />
        </div>
        <div class="form-row">
            <label for="edit-term">Học kỳ</label>
            <select id="add-term" class="filter-select">
                <option value="1">Học Kỳ 1</option>
                <option value="2">Học Kỳ 2</option>
                <option value="3">Học Kỳ 3</option>
                <option value="4">Học Kỳ 4</option>
                <option value="5">Học Kỳ 5</option>
                <option value="6">Học Kỳ 6</option>
                <option value="7">Học Kỳ 7</option>
                <option value="8">Học Kỳ 8</option>
                <option value="9">Học Kỳ 9</option>
            </select>
        </div>
        <div class="form-row">
            <label for="edit-course-name">Tên môn học</label>
            <select id="edit-course-name" class="filter-select">
                @if (subjects != null)
                {
                    @foreach (var item in subjects.Items)
                    {
                        <option value="@item.MaMh">@item.TenMh</option>
                    }
                }
            </select>
        </div>
        <div class="form-row">
            <label for="edit-lecturer">Giảng viên</label>
            <select id="edit-lecturer" class="filter-select">
                @if (teachers != null)
                {
                    @foreach (var item in teachers.Items)
                    {
                        <option value="@item.MaGV">@item.Ho  @item.Ten  </option>
                    }
                }
            </select>
        </div>
        <div class="form-row two-cols">
            <div>
                <label for="edit-max-size">Sĩ số tối đa</label>
                <input type="number" id="edit-max-size" min="0" />
            </div>
            <div>
                <label for="edit-weekdays">Dạy thứ (ví dụ: Thứ 2,4,5)</label>
                <input type="text" id="edit-weekdays" />
            </div>
        </div>
        <div class="form-row two-cols">
            <div>
                <label for="edit-start-date">Thời gian bắt đầu</label>
                <input type="text" id="edit-start-date" class="date-picker" />
            </div>
            <div>
                <label for="edit-end-date">Thời gian kết thúc</label>
                <input type="text" id="edit-end-date" class="date-picker" />
            </div>
        </div>
        <div class="form-row">
            <label for="edit-status">Trạng thái</label>
            <select id="edit-status" class="filter-select">
                <option value="open">Mở</option>
                <option value="closed">Đóng</option>
            </select>
        </div>
        <div class="form-actions">
            <button type="button" id="submit-edit-course" class="add-course-btn">Lưu thay đổi</button>
            <button type="submit" id="cancel-edit-course" class="filter-btn">Hủy</button>
        </div>
    </form>
</aside>
@section Scripts {
    <script src="~/assets/js/open-course.js"></script>
}