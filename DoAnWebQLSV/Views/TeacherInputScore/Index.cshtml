@{
    var scores = ViewBag.Scores;
}
@section Styles {
    <link rel="stylesheet" href="~/assets/css/my-score.css" />
}
<section class="content-wrap">
    <div class="page-title-row">
        <div class="page-title-group">
            <div class="title-icon"><i class="fa-regular fa-square-plus"></i></div>
            <div>
                <h1>Nhập điểm</h1>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="table-toolbar">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Tìm kiếm theo tên môn" />
            </div>
        </div>

        <div class="table-responsive">
            <table class="course-table">
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>Môn học</th>
                        <th>Học kỳ</th>
                        <th>Niên khóa</th>
                        <th>Chuyên cần</th>
                        <th>Giữa kỳ</th>
                        <th>Cuối kỳ</th>
                        <th>Điểm tổng</th>
                        <th>Xếp loại</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (scores?.Items != null)
                    {
                        int stt = 1;

                        foreach (var item in scores.Items)
                        {
                            <tr>
                                <td>@stt</td>

                                <td>
                                    <strong>@item.TenMh</strong>
                                    <small>@item.MaMh · @item.SoTinChi TC</small>
                                </td>

                                <td>
                                    <span class="term">
                                        Học kỳ @item.HocKy
                                    </span>
                                </td>

                                <td>
                                    <span class="academic-year">
                                        @item.NienKhoa
                                    </span>
                                </td>

                                <td>@item.DiemCc.ToString("0.0")</td>
                                <td>@item.DiemGk.ToString("0.0")</td>
                                <td>@item.DiemCk.ToString("0.0")</td>
                                <td>@item.DiemTong.ToString("0.0")</td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(item.XepLoai)
                                                                ? "Chưa xếp loại"
                                                                : item.XepLoai)
                        </td>

                                                    <td>
                                                        <button type="button"
                                                                class="action-btn edit-btn"
                                                                data-maltc="@item.MaLtc"
                                                                data-masv="@item.MaSv"
                                                                data-diemcc="@item.DiemCc"
                                                                data-diemgk="@item.DiemGk"
                                                                data-diemck="@item.DiemCk"
                                                                title="Sửa điểm"
                                                                aria-label="Sửa điểm">
                                                            <i class="fa-solid fa-pen"></i>
                                                        </button>
                                                    </td>
                                                </tr>

                                                stt++;
                        }
                    }
                </tbody>
            </table>
        </div>
        <div class="pagination-wrapper">
            <nav class="pagination">
                <button class="pagination-btn pagination-prev" title="Trang trước">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>
                <button class="pagination-page active">1</button>
                <button class="pagination-btn pagination-next" title="Trang sau">
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </nav>
        </div>
    </div>
    
</section>
