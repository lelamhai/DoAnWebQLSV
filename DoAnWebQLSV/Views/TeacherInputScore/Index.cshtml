@section Styles {
    <link rel="stylesheet" href="~/assets/css/my-score.css" />
}
<section class="content-wrap">
    <div class="page-title-row">
        <div class="page-title-group">
            <div class="title-icon"><i class="fa-regular fa-square-plus"></i></div>
            <div>
                <h1>Nhập điểm</h1>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="table-toolbar">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Tìm kiếm theo tên môn" />
            </div>
        </div>

        <div class="table-responsive">
            <table class="course-table">
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>Môn học</th>
                        <th>Học kỳ</th>
                        <th>Niên khóa</th>
                        <th>Chuyên cần</th>
                        <th>Giữa kỳ</th>
                        <th>Cuối kỳ</th>
                        <th>Điểm tổng</th>
                        <th>Xếp loại</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td><strong>Cấu trúc dữ liệu và giải thuật</strong><small>INT1002 · 3 TC</small></td>
                        <td><span class="term">Học kỳ 1</span></td>
                        <td><span class="academic-year">2025-2026</span></td>
                        <td>8.0</td>
                        <td>7.5</td>
                        <td>8.0</td>
                        <td>8.0</td>
                        <td>Giỏi</td>
                        <td><button type="button" class="action-btn edit-btn" data-malop="" title="Sửa" aria-label="Sửa lớp học"><i class="fa-solid fa-pen"></i></button></td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td><strong>Nhập môn lập trình</strong><small>INT1001 · 3 TC</small></td>
                        <td><span class="term">Học kỳ 1</span></td>
                        <td><span class="academic-year">2025-2026</span></td>
                        <td>8.0</td>
                        <td>7.5</td>
                        <td>8.0</td>
                        <td>8.0</td>
                        <td>Giỏi</td>
                        <td><button type="button" class="action-btn edit-btn" data-malop="" title="Sửa" aria-label="Sửa lớp học"><i class="fa-solid fa-pen"></i></button></td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="pagination-wrapper">
            <nav class="pagination">
                <button class="pagination-btn pagination-prev" title="Trang trước">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>
                <button class="pagination-page active">1</button>
                <button class="pagination-btn pagination-next" title="Trang sau">
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </nav>
        </div>
    </div>
    
</section>
