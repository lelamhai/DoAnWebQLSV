@{
    var points = ViewBag.Points;
}
@section Styles {
    <link rel="stylesheet" href="~/assets/css/my-score.css" />
}
<section class="content-wrap">

    <div class="score-info-summary">
        <div class="score-info-card">
            <div class="score-info-icon"><i class="fa-solid fa-book-open"></i></div>
            <div class="score-info-content">
                <span class="score-info-label">Số môn</span>
                <strong>1/50</strong>
            </div>
        </div>
        <div class="score-info-card">
            <div class="score-info-icon"><i class="fa-solid fa-certificate"></i></div>
            <div class="score-info-content">
                <span class="score-info-label">Tín chỉ tích lũy</span>
                <strong>3/152</strong>
            </div>
        </div>
        <div class="score-info-card">
            <div class="score-info-icon"><i class="fa-solid fa-star"></i></div>
            <div class="score-info-content">
                <span class="score-info-label">GPA</span>
                <strong>8.5/10</strong>
            </div>
        </div>
        <div class="score-info-card">
            <div class="score-info-icon"><i class="fa-solid fa-trophy"></i></div>
            <div class="score-info-content">
                <span class="score-info-label">Xếp loại</span>
                <strong>Giỏi</strong>
            </div>
        </div>
    </div>

    <div class="page-title-row">
        <div class="page-title-group">
            <div class="title-icon"><i class="fa-regular fa-square-plus"></i></div>
            <div>
                <h1>Bảng điểm</h1>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="table-toolbar">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Tìm kiếm theo tên môn" />
            </div>
        </div>

        <div class="table-responsive">
            <table class="course-table">
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>Môn học</th>
                        <th>Học kỳ</th>
                        <th>Niên khóa</th>
                        <th>Chuyên cần</th>
                        <th>Giữa kỳ</th>
                        <th>Cuối kỳ</th>
                        <th>Điểm tổng</th>
                    </tr>
                </thead>
                <tbody>

                    @if (points != null)
                    {
						int stt = 1;
                        @foreach (var item in points.Items)
                        {
                            <tr>
                                <td>@stt</td>
                                <td><strong>@item.TenMH</strong><small>@item.MaMH · @item.SoTinChi TC</small></td>
                                <td><span class="term">Học kỳ @item.HocKy</span></td>
                                <td><span class="academic-year">@item.NienKhoa</span></td>
                                <td>@item.DiemCC</td>
                                <td>@item.DiemGK</td>
                                <td>@item.DiemCK</td>
                                <td class="no-right">@item.DiemTong</td>
                            </tr>
                        }
						stt++;
                    }

                </tbody>
            </table>
        </div>
        <div class="pagination-wrapper">
            <nav class="pagination">
                @if (points != null)
                {
                    <a href="?page=1" class="pagination-btn pagination-prev" title="Trang trước"><i class="fa-solid fa-chevron-left"></i></a>
                    for (int i = 1; i <= points.Pagination.TotalPages; i++)
                    {
                        if (i == points.Pagination.Page)
                        {
                            <a href="?page=@i" class="pagination-page active">@i</a>
                        }
                        else
                        {
                            <a href="?page=@i" class="pagination-page">@i</a>
                        }
                    }
                    <a href="?page=@points.Pagination.TotalPages" class="pagination-btn pagination-next" title="Trang sau"><i class="fa-solid fa-chevron-right"></i></a>
                }
            </nav>
        </div>
    </div>
  
</section>

@section Scripts {
    <script src="~/assets/js/my-score.js"></script>
}