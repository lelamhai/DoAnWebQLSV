                        <option value="">Học kỳ 1</option>
                        <option value="">Học kỳ 1</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label for="academic-year">Niên khóa</label>
                    <input type="text" id="academic-year-picker" class="year-picker" placeholder="Chọn năm" data-date-format="yyyy" data-start-view="2" />
                </div>
            </div>
        </div>


