@using Microsoft.AspNetCore.Http

@{
    var role = Context.Session.GetString("Role");
    switch(role)
    {
        case "GV":
            Layout = "_GiangVien";
            break;
        case "SV":
            Layout = "_SinhVien";
            break;
        default:
            Layout = "_NhanVien";
            break;
	}
}