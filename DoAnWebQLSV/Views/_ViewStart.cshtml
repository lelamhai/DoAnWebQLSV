@using Microsoft.AspNetCore.Http

@{
    var role = Context.Session.GetString("Role");
    switch(role)
    {
        case "Admin":
            Layout = "_Admin";
            break;
        case "NV":
            Layout = "_NhanVien";
            break;
        case "GV":
            Layout = "_GiangVien";
            break;
        case "SV":
            Layout = "_SinhVien";
            break;
        default:
            Layout = "_Layout";
            break;
	}
   




