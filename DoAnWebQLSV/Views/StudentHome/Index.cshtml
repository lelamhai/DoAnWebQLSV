@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@section Styles {
    <link rel="stylesheet" href="~/assets/css/dashboard.css" />
}
<section class="content-wrap dashboard-wrap">
    <div class="dashboard-stats">
        <article class="dashboard-stat-card">
            <div class="dashboard-stat-icon"><i class="fa-regular fa-clipboard"></i></div>
            <div class="dashboard-stat-content">
                <span class="dashboard-stat-label">Số môn đã đăng ký</span>
                <strong>7 môn</strong>
            </div>
        </article>
        <article class="dashboard-stat-card">
            <div class="dashboard-stat-icon"><i class="fa-solid fa-award"></i></div>
            <div class="dashboard-stat-content">
                <span class="dashboard-stat-label">Tổng tín chỉ</span>
                <strong>20 tín chỉ</strong>
            </div>
        </article>
        <article class="dashboard-stat-card">
            <div class="dashboard-stat-icon"><i class="fa-solid fa-graduation-cap"></i></div>
            <div class="dashboard-stat-content">
                <span class="dashboard-stat-label">Điểm trung bình</span>
                <strong>7.95</strong>
            </div>
        </article>
        <article class="dashboard-stat-card">
            <div class="dashboard-stat-icon"><i class="fa-solid fa-wallet"></i></div>
            <div class="dashboard-stat-content">
                <span class="dashboard-stat-label">Trạng thái học phí</span>
                <strong>Đã thanh toán</strong>
            </div>
        </article>
    </div>

    <div class="dashboard-grid">
        <aside class="dashboard-panel dashboard-right-column">
            <div class="dashboard-panel-header">
                <div>
                    <h2>Thông tin sinh viên</h2>
                </div>
            </div>

            <div class="student-card">
                <div class="student-avatar">LH</div>
                <div class="student-info">
                    <strong>Lê Lam Hải</strong>
                    <span>SV00000001</span>
                    <small>Công nghệ thông tin</small>
                </div>
            </div>

            <div class="student-detail-list">
                <div class="student-detail-item">
                    <span class="student-detail-label">Trạng thái</span>
                    <strong>Đang học</strong>
                </div>
                <div class="student-detail-item">
                    <span class="student-detail-label">Lớp sinh hoạt</span>
                    <strong>DTCN-K23A</strong>
                </div>
                <div class="student-detail-item">
                    <span class="student-detail-label">Cố vấn học tập</span>
                    <strong>Nguyễn Văn An</strong>
                </div>
            </div>
        </aside>

        <section class="dashboard-panel dashboard-actions-panel">
            <div class="dashboard-panel-header">
                <div>
                    <h2>Thời khóa biểu</h2>
                </div>
            </div>

            <div class="dashboard-actions">
                <a class="dashboard-action-card">
                    <div class="dashboard-action-content">
                        <h3>Quản lý dự án phần mềm</h3>
                        <p>Giảng viên: Nguyễn Văn Hoàng.</p>
                    </div>
                </a>

                <a class="dashboard-action-card">
                    <div class="dashboard-action-content">
                        <h3>Lập trình hướng đối tượng</h3>
                        <p>Giảng viên: Trần Thị Hoa.</p>
                    </div>
                </a>
            </div>
        </section>
    </div>
</section>
@section Scripts {
    <script src="~/assets/js/dashboard.js"></script>
}